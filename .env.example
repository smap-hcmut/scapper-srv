# App Config
MODE=production
DEBUG=False

# RabbitMQ
# Shared/prod-like broker:
# RABBITMQ_URL=amqp://admin:21042004@172.16.21.206:5672/
# Local isolated broker for E2E/runtime debugging:
RABBITMQ_URL=amqp://admin:21042004@localhost:5673/

# MinIO (Required if MODE=production)
MINIO_ENDPOINT=172.16.21.10:9000
MINIO_ACCESS_KEY=tantai
MINIO_SECRET_KEY=21042004
MINIO_BUCKET=ingest-data
MINIO_USE_SSL=False
MINIO_REGION=us-east-1

# TinLikeSub API
API_BASE_URL=http://localhost:8104
API_KEY=your_api_key
API_SECRET_KEY=your_secret_key

# Worker
WORKER_PREFETCH_COUNT=1
OUTPUT_DIR=output
